{
  "id": "sea-battle",
  "name": "Sea Battle",
  "version": "1.0.0",
  "description": "Async turn-based naval grid game — challenge a family member, place your fleet, and fire away.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "games",
  "tags": ["games", "kids", "strategy", "turn-based"],
  "icon": "⚓",
  "storage": "db",
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "nav": { "label": "Sea Battle" },
  "publishes": ["sea-battle.game-started", "game.completed"],
  "alert_on": ["sea-battle.game-started", "game.completed"],
  "row_policies": {
    "app_sea_battle__sea_battle_games": {
      "kind": "party_scoped",
      "member_columns": ["challenger_id", "opponent_id"],
      "self_column": "challenger_id"
    },
    "app_sea_battle__sea_battle_ships": {
      "kind": "party_scoped",
      "member_columns": ["owner_id"]
    },
    "app_sea_battle__sea_battle_shots": {
      "kind": "party_scoped",
      "member_columns": ["shooter_id", "target_player_id"]
    }
  }
}
